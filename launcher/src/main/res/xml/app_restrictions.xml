<?xml version="1.0" encoding="utf-8"?>
<restrictions xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Main Tile Configuration -->
    <restriction
        android:key="main_tile_package"
        android:title="Main Tile Package Name"
        android:restrictionType="string"
        android:description="@string/main_tile_package_desc"
        android:defaultValue="com.motive.driver" />

    <restriction
        android:key="main_tile_activity"
        android:title="Main Tile Activity"
        android:restrictionType="string"
        android:description="@string/main_tile_activity_desc"
        android:defaultValue="com.motive.driver.MainActivity" />

    <!-- Dispatch Configuration -->
    <restriction
        android:key="dispatch_url"
        android:title="Dispatch System URL"
        android:restrictionType="string"
        android:description="@string/dispatch_url_desc"
        android:defaultValue="https://fdxtools.fedex.com/grdlhldispatch" />

    <restriction
        android:key="dispatch_login_url"
        android:title="Dispatch Login URL"
        android:restrictionType="string"
        android:description="@string/dispatch_login_url_desc"
        android:defaultValue="" />

    <restriction
        android:key="dispatch_auto_login_redirect"
        android:title="Dispatch Auto Login Redirect"
        android:restrictionType="bool"
        android:description="@string/dispatch_auto_login_redirect_desc"
        android:defaultValue="false" />

    <restriction
        android:key="dispatch_expandable"
        android:title="Dispatch Expandable"
        android:restrictionType="bool"
        android:description="@string/dispatch_expandable_desc"
        android:defaultValue="true" />

    <!-- Navigation Configuration -->
    <restriction
        android:key="navigation_package"
        android:title="Navigation Package Name"
        android:restrictionType="string"
        android:description="@string/navigation_package_desc"
        android:defaultValue="com.google.android.apps.maps" />

    <restriction
        android:key="navigation_expandable"
        android:title="Navigation Expandable"
        android:restrictionType="bool"
        android:description="@string/navigation_expandable_desc"
        android:defaultValue="true" />

    <!-- PrePass Configuration -->
    <restriction
        android:key="prepass_package"
        android:title="PrePass Package Name"
        android:restrictionType="string"
        android:description="@string/prepass_package_desc"
        android:defaultValue="com.prepass.app" />

    <restriction
        android:key="prepass_expandable"
        android:title="PrePass Expandable"
        android:restrictionType="bool"
        android:description="@string/prepass_expandable_desc"
        android:defaultValue="true" />

    <!-- ELD Configuration -->
    <restriction
        android:key="eld_package"
        android:title="ELD Package Name"
        android:restrictionType="string"
        android:description="@string/eld_package_desc"
        android:defaultValue="com.eld.app" />

    <!-- Layout Configuration -->
    <restriction
        android:key="main_tile_normal_size"
        android:title="Main Tile Normal Size"
        android:restrictionType="string"
        android:description="@string/main_tile_normal_size_desc"
        android:defaultValue="0.7" />

    <restriction
        android:key="main_tile_compressed_size"
        android:title="Main Tile Compressed Size"
        android:restrictionType="string"
        android:description="@string/main_tile_compressed_size_desc"
        android:defaultValue="0.4" />

    <restriction
        android:key="expanded_tile_size"
        android:title="Expanded Tile Size"
        android:restrictionType="string"
        android:description="@string/expanded_tile_size_desc"
        android:defaultValue="0.3" />

    <!-- Driver Safety (Scaffold) -->
    <restriction
        android:key="interaction_lock_when_moving"
        android:title="Lock Tile Interaction While Moving"
        android:restrictionType="bool"
        android:description="@string/interaction_lock_when_moving_desc"
        android:defaultValue="false" />

    <restriction
        android:key="interaction_lock_demo_active"
        android:title="Interaction Lock Demo Active"
        android:restrictionType="bool"
        android:description="@string/interaction_lock_demo_active_desc"
        android:defaultValue="false" />

    <restriction
        android:key="default_launcher_prompt_enabled"
        android:title="Default Launcher Prompt Enabled"
        android:restrictionType="bool"
        android:description="@string/default_launcher_prompt_enabled_desc"
        android:defaultValue="false" />

    <!-- Esper Integration (Future-ready) -->
    <restriction
        android:key="esper_sdk_enabled"
        android:title="Enable Esper SDK Integration"
        android:restrictionType="bool"
        android:description="@string/esper_sdk_enabled_desc"
        android:defaultValue="false" />

    <restriction
        android:key="esper_api_token"
        android:title="Esper API Token"
        android:restrictionType="string"
        android:description="@string/esper_api_token_desc"
        android:defaultValue="" />

    <restriction
        android:key="esper_tenant_url"
        android:title="Esper Tenant URL"
        android:restrictionType="string"
        android:description="@string/esper_tenant_url_desc"
        android:defaultValue="" />

    <restriction
        android:key="esper_backend_alias_endpoint"
        android:title="Alias Backend Endpoint"
        android:restrictionType="string"
        android:description="@string/esper_backend_alias_endpoint_desc"
        android:defaultValue="" />

    <restriction
        android:key="esper_enterprise_id"
        android:title="Esper Enterprise ID"
        android:restrictionType="string"
        android:description="@string/esper_enterprise_id_desc"
        android:defaultValue="" />

    <restriction
        android:key="esper_identity_hard_disable"
        android:title="Hard Disable Identity"
        android:restrictionType="bool"
        android:description="@string/esper_identity_hard_disable_desc"
        android:defaultValue="false" />

    <restriction
        android:key="esper_config_revision"
        android:title="Esper Config Revision"
        android:restrictionType="string"
        android:description="@string/esper_config_revision_desc"
        android:defaultValue="" />

    <restriction
        android:key="esper_use_managed_alias"
        android:title="Enable Alias Display"
        android:restrictionType="bool"
        android:description="@string/esper_use_managed_alias_desc"
        android:defaultValue="true" />

    <restriction
        android:key="esper_device_alias"
        android:title="Managed Device Alias"
        android:restrictionType="string"
        android:description="@string/esper_device_alias_desc"
        android:defaultValue="" />

    <restriction
        android:key="esper_device_name"
        android:title="Managed Device Name"
        android:restrictionType="string"
        android:description="@string/esper_device_name_desc"
        android:defaultValue="" />

    <restriction
        android:key="esper_show_device_name"
        android:title="Show Device Name"
        android:restrictionType="bool"
        android:description="@string/esper_show_device_name_desc"
        android:defaultValue="true" />

    <!-- Diagnostics -->
    <restriction
        android:key="diagnostics_panel_enabled"
        android:title="Diagnostics Panel Enabled"
        android:restrictionType="bool"
        android:description="@string/diagnostics_panel_enabled_desc"
        android:defaultValue="false" />

    <restriction
        android:key="diagnostics_show_warnings"
        android:title="Diagnostics Show Warnings"
        android:restrictionType="bool"
        android:description="@string/diagnostics_show_warnings_desc"
        android:defaultValue="true" />

</restrictions>
